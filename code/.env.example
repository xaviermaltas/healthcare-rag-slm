# Healthcare RAG System - Template de configuració
# Copia aquest fitxer com a .env i ajusta els valors al teu entorn:
#   cp .env.example .env

# Application
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# API
API_HOST=0.0.0.0
API_PORT=8000

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=healthcare_rag

# Embeddings
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DEVICE=cpu

# BioPortal API (obtenir a https://bioportal.bioontology.org/account)
BIOPORTER_API_KEY=your_api_key_here

# MedlinePlus API
MEDLINEPLUS_BASE_URL=https://wsearch.nlm.nih.gov/ws/query

# Retrieval settings
RETRIEVAL_TOP_K=10
RERANK_TOP_K=5

# Generation settings
GENERATION_MAX_TOKENS=1000
GENERATION_TEMPERATURE=0.7

# Language
DEFAULT_LANGUAGE=es
